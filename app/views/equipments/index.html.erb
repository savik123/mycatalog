<div class="container mt-3">

  <%= form_with url: equipments_path, method: :get, local: true do %>
    <div class="input-group mb-4">

      <%= text_field_tag :query, params[:query],
                         placeholder: "Поиск оборудования...",
                         class: "form-control" %>

      <button class="btn btn-primary">Поиск</button>

    </div>
  <% end %>

</div>

<div class="container mt-4">

  <h1 class="mb-4 text-center">Каталог оборудования</h1>

  <div class="row">

    <% @equipments.each do |equipment| %>

      <div class="col-12 col-sm-6 col-md-4 col-lg-3 mb-4 d-flex">

        <div class="card shadow-sm h-100 w-100">

          <div class="position-relative">

            <%= button_to toggle_favorite_equipment_path(equipment),
                          method: :post,
                          class: "favorite-btn position-absolute top-0 end-0 m-2 #{'active' if favorite?(equipment)}" do %>
              ⭐
            <% end %>

            <% if equipment.images.any? %>
              <%= image_tag equipment.images.first, class: "card-img-top fixed-image" %>
            <% end %>

          </div>

          <div class="card-body">

            <h5 class="card-title"><%= equipment.name %></h5>

            <p class="card-text">
              <strong>Назначение:</strong><br>
              <%= truncate(equipment.purpose, length: 100) %>
            </p>

            <%= link_to "Подробнее", equipment_path(equipment), class: "btn btn-primary mt-auto" %>

          </div>

        </div>

      </div>

    <% end %>

  </div>
</div>